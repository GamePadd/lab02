<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Как вы себя чувствуете?"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Оценка настроения:"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />
    
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/mood1"
            android:layout_width="8dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:src="@android:drawable/star_big_off"
            android:contentDescription="Настроение 1"
            android:padding="8dp"/>

        <ImageView
            android:id="@+id/mood2"
            android:layout_width="8dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:src="@android:drawable/star_big_off"
            android:contentDescription="Настроение 2"
            android:padding="8dp"/>

        <ImageView
            android:id="@+id/mood3"
            android:layout_width="8dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:src="@android:drawable/star_big_off"
            android:contentDescription="Настроение 3"
            android:padding="8dp"/>

        <ImageView
            android:id="@+id/mood4"
            android:layout_width="8dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:src="@android:drawable/star_big_off"
            android:contentDescription="Настроение 4"
            android:padding="8dp"/>

        <ImageView
            android:id="@+id/mood5"
            android:layout_width="8dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:src="@android:drawable/star_big_off"
            android:contentDescription="Настроение 5"
            android:padding="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Комментарий:"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/commentEditText"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:inputType="textMultiLine"
        android:gravity="top|start"
        android:padding="12dp"
        android:hint="Введите ваш комментарий здесь..."
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Очистить"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#F44336" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сохранить"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#4CAF50" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:padding="15dp"
        android:layout_marginTop="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статистика за неделю"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">

            <!-- Элемент дня-->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Пн"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats1"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#09C300"
                    android:text="4"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Вт"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#FFCD00"
                    android:text="3"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Ср"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats3"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#09C300"
                    android:text="5"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Чт"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats4"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#FD8B00"
                    android:text="2"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Пт"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats5"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#09C300"
                    android:text="4"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginRight="2dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Сб"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats6"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#09C300"
                    android:text="5"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:text="Вс"
                    android:gravity="center"
                    android:layout_marginBottom="5dp"/>
                <TextView
                    android:id="@+id/stats7"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="#09C300"
                    android:text="4"
                    android:textColor="@color/white"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Цвет показывает оценку настроения (1-5)"
            android:textSize="10sp"/>
    </LinearLayout>
</LinearLayout>